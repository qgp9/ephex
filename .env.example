# Ephex CLI helper defaults

# Worker origin, with or without /api/upload.
EPHEX_BASE_URL=https://your-worker-domain

# API token from the Profile page.
EPHEX_API_TOKEN=

# Upload mode: plain, symmetric, public-key
EPHEX_ENCRYPTION_MODE=plain

# Optional symmetric key for uploads. If empty, ephex-upload.js generates one.
EPHEX_SYMMETRIC_KEY=

# Public key PEM path or inline PEM contents for public-key uploads.
EPHEX_PUBLIC_KEY=~/.config/ephex/public.pem

# Optional upload defaults.
EPHEX_EXPIRES_HOURS=
EPHEX_MAX_DOWNLOADS=

# Download helper defaults.
EPHEX_PRIVATE_KEY=~/.config/ephex/private.pem
EPHEX_DOWNLOAD_DIR=~/Downloads/ephex

# Download collision policy: suffix, overwrite, fail
EPHEX_OVERWRITE_MODE=suffix
